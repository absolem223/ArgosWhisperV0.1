{
  "name": "argos-whisper",
  "version": "0.1.0",
  "description": "Floating Electron desktop app for real-time Whisper transcription + LLM text transformation",
  "main": "dist/main/index.js",
  "scripts": {
    "build:main": "webpack --config webpack.main.config.js",
    "build:renderer": "webpack --config webpack.renderer.config.js",
    "build": "pnpm run build:main && pnpm run build:renderer",
    "start": "pnpm run build && electron .",
    "dev:main": "webpack --config webpack.main.config.js --watch",
    "dev:renderer": "webpack --config webpack.renderer.config.js --watch",
    "dev": "concurrently \"pnpm run dev:main\" \"pnpm run dev:renderer\" \"wait-on dist/main/index.js && electron .\"",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "electron",
    "whisper",
    "transcription",
    "llm",
    "voice",
    "desktop"
  ],
  "author": "Argos Project",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/nspell": "^2.1.5",
    "concurrently": "^8.2.2",
    "css-loader": "^6.8.1",
    "electron": "^28.0.0",
    "html-webpack-plugin": "^5.5.4",
    "mini-css-extract-plugin": "^2.7.6",
    "style-loader": "^3.3.3",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "wait-on": "^7.2.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "dictionary-en": "^3.2.0",
    "dictionary-es": "^3.0.0",
    "electron-store": "^8.1.0",
    "node-fetch": "^3.3.2",
    "node-record-lpcm16": "^1.0.1",
    "nspell": "^2.1.5"
  }
}
